<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.demo1.mapper.BrowseHistoryMapper">

    <resultMap id="BrowseHistoryVOMap" type="org.example.demo1.vo.BrowseHistoryVO">
        <id column="id" property="id"/>
        <result column="case_id" property="caseId"/>
        <result column="title_zh" property="titleZh"/>
        <result column="title_en" property="titleEn"/>
        <result column="case_reason" property="caseReason"/>
        <result column="country" property="country"/>
        <result column="court" property="court"/>
        <result column="case_type" property="caseType"/>
        <result column="importance_score" property="importanceScore"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="selectBrowseHistoryPage" resultMap="BrowseHistoryVOMap">
        SELECT
            bh.id,
            bh.case_id,
            lc.title_zh,
            lc.title_en,
            lc.case_reason,
            lc.country,
            lc.court,
            lc.case_type,
            lc.importance_score,
            bh.created_at
        FROM browse_history bh
        LEFT JOIN legal_case lc ON bh.case_id = lc.id AND lc.is_deleted = 0
        WHERE bh.user_id = #{userId}
        ORDER BY bh.created_at DESC
    </select>

</mapper>
